PORT=3001
MONGODB_URI=mongodb://localhost:27017/pizzadb
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=1d
JWT_ISSUER=pizza-palace-api
JWT_AUDIENCE=pizza-palace-client

CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
REQUIRE_EMAIL_VERIFICATION=false
ENABLE_INVENTORY_CRON=true

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password_or_app_password
FROM_EMAIL=your_email@example.com
ADMIN_EMAIL=admin@example.com

SEED_ADMIN_EMAIL=admin@pizzapalace.com
SEED_ADMIN_PASSWORD=admin12345
SEED_USER_EMAIL=user@pizzapalace.com
SEED_USER_PASSWORD=user12345
